{
  "manifest_version": 3,
  "name": "Hello YouTube Insert",
  "version": "1.0.0",
  "description": "Show a fullscreen YouTube meme overlay when text contains never.",
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
